{
  "expo": {
    "name": "society-portl",
    "slug": "society-portl",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "scheme": "society-portl",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "package": "com.shiwamshahare.societyportl"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "11152d99-e101-4e74-916f-46df40a75f63"
      }
    },
    "owner": "shiwamshahare",
    "plugins": [
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    "entryPoint": "index.js"
  }
}
